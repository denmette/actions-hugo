@startuml
title actions-hugo architecture

skinparam componentStyle rectangle
skinparam packageStyle rectangle
skinparam shadowing false

actor "GitHub workflow consumer" as Consumer
actor "Maintainer" as Maintainer

package "Published GitHub Action" {
  [action.yml] as action
  [lib/index.js\nbundled action] as bundle
}

package "TypeScript runtime" {
  [src/index.ts] as entry
  [src/main.ts] as main
  [src/get-latest-version.ts] as latest
  [src/hugo-assets.ts] as assets
  [src/get-url.ts] as geturl
  [src/installer.ts] as installer
  [src/get-os.ts] as getos
  [src/get-arch.ts] as getarch
  [src/constants.ts] as constants
}

package "External systems" {
  [Homebrew formula API] as brew
  [GitHub Releases API] as ghreleases
  [GitHub release assets] as ghassets
  [Runner filesystem] as fs
  [Runner PATH] as pathenv
}

package "Repository automation" {
  [test.yml] as testwf
  [test-action.yml] as actionwf
  [dev-image.yml] as devwf
  [release.yml] as releasewf
  [update-major-tag.yml] as tagwf
  [security workflows] as secwf
}

package "Local contributor tooling" {
  [package.json] as pkg
  [Corepack + npm] as corepack
  [Makefile] as makefile
  [Dockerfile] as dockerfile
  [Husky hooks] as husky
  [Vitest test suites] as tests
}

Consumer --> action
action --> bundle
bundle --> entry
entry --> main
main --> latest : resolve latest or pinned version
main --> installer : install selected version
main --> constants

latest --> brew : primary latest lookup
latest --> ghreleases : fallback latest lookup\nand asset metadata lookup
latest --> assets
geturl --> assets

installer --> getos
installer --> getarch
installer --> geturl : direct candidate URLs
installer --> latest : fallback asset URL lookup
installer --> ghassets : download archive
installer --> fs : extract + move binary
installer --> pathenv : add Hugo bin dir

Maintainer --> pkg
pkg --> corepack
pkg --> husky
pkg --> tests
dockerfile --> corepack
makefile --> dockerfile
makefile --> devwf

testwf --> corepack
testwf --> tests
testwf --> bundle : verify committed artifact
actionwf --> action
devwf --> dockerfile
devwf --> corepack
releasewf --> testwf : workflow_run gate
releasewf --> bundle : verify committed artifact
releasewf --> pkg : semantic-release toolchain
tagwf --> releasewf
secwf --> action
secwf --> testwf

note right of latest
latest resolution now prefers Brew
and falls back to GitHub releases
when Brew lookup fails.
end note

note bottom of bundle
lib/index.js is committed output
generated from src/ via ncc.
CI verifies it stays in sync.
end note

@enduml
