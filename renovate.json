{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "timezone": "Europe/Brussels",
  "schedule": [
    "after 10pm every weekday",
    "before 5am every weekday",
    "every weekend"
  ],
  "labels": ["dependencies", "renovate"],
  "dependencyDashboard": true,
  "rebaseWhen": "behind-base-branch",
  "prConcurrentLimit": 8,
  "rangeStrategy": "bump",
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["every weekend"]
  },
  "packageRules": [
    {
      "description": "Keep major Node runtime baseline moves separate from normal maintenance work.",
      "matchManagers": ["npm"],
      "matchPackageNames": ["node", "@types/node"],
      "matchUpdateTypes": ["major"],
      "groupName": "node-runtime-major",
      "groupSlug": "node-runtime-major",
      "separateMajorMinor": true
    },
    {
      "description": "Keep supported Node baseline maintenance updates together without mixing them with broader tooling work.",
      "matchManagers": ["npm"],
      "matchPackageNames": ["node", "@types/node"],
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "groupName": "node-runtime-maintenance",
      "groupSlug": "node-runtime-maintenance"
    },
    {
      "description": "Review GitHub Actions workflow maintenance updates together.",
      "matchManagers": ["github-actions"],
      "matchPackageNames": [
        "actions/checkout",
        "actions/setup-node",
        "actions/upload-artifact",
        "actions/download-artifact",
        "actions/dependency-review-action",
        "codecov/codecov-action",
        "github/codeql-action"
      ],
      "groupName": "github-actions-workflows",
      "groupSlug": "github-actions-workflows"
    },
    {
      "description": "Keep artifact action majors grouped with the wider workflow maintenance work instead of opening isolated PRs.",
      "matchManagers": ["github-actions"],
      "matchPackageNames": [
        "actions/upload-artifact",
        "actions/download-artifact"
      ],
      "matchUpdateTypes": ["major"],
      "groupName": "github-actions-workflows",
      "groupSlug": "github-actions-workflows"
    },
    {
      "description": "Keep CodeQL workflow updates in the main workflow maintenance group so deprecation-driven upgrades are not isolated.",
      "matchManagers": ["github-actions"],
      "matchPackageNames": ["github/codeql-action"],
      "groupName": "github-actions-workflows",
      "groupSlug": "github-actions-workflows"
    },
    {
      "description": "Review runner image updates together.",
      "matchManagers": ["github-actions"],
      "matchDepNames": ["ubuntu"],
      "groupName": "github-actions-runner-images",
      "groupSlug": "github-actions-runner-images"
    },
    {
      "description": "Treat the newer GitHub Actions toolkit majors as one migration unit.",
      "matchManagers": ["npm"],
      "matchPackageNames": [
        "@actions/core",
        "@actions/exec",
        "@actions/io",
        "@actions/tool-cache"
      ],
      "groupName": "github-actions-toolkit-majors",
      "groupSlug": "github-actions-toolkit-majors"
    },
    {
      "description": "Keep npm tooling updates together.",
      "matchManagers": ["npm"],
      "matchPackageNames": [
        "eslint",
        "@typescript-eslint/eslint-plugin",
        "@typescript-eslint/parser",
        "typescript",
        "prettier",
        "eslint-plugin-jest"
      ],
      "groupName": "tooling-stack",
      "groupSlug": "tooling-stack"
    },
    {
      "description": "Keep test-stack updates together.",
      "matchManagers": ["npm"],
      "matchPackageNames": [
        "jest",
        "ts-jest",
        "@types/jest",
        "@types/istanbul-lib-report",
        "nock"
      ],
      "groupName": "test-stack",
      "groupSlug": "test-stack"
    },
    {
      "description": "Keep local workflow tooling together.",
      "matchManagers": ["npm"],
      "matchPackageNames": ["husky", "lint-staged"],
      "groupName": "local-workflow-tooling",
      "groupSlug": "local-workflow-tooling"
    }
  ]
}
