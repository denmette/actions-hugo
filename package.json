{
  "name": "actions-hugo",
  "version": "3.0.0",
  "description": "GitHub Actions for Hugo",
  "type": "module",
  "main": "lib/index.js",
  "packageManager": "npm@11.12.1+sha512.cdca14b85d647b3192028d02aadbe82d75f79a446aceea9874be98e6d768f20ebd3555770a48d0e9906106007877bbc690f715e9372f2e2dc644a3c3157fb14c",
  "engines": {
    "node": ">=24.14.1",
    "npm": ">=11.12.1"
  },
  "scripts": {
    "all": "npm run format:check && npm run lint && npm test",
    "lint": "eslint ./{src,__tests__}/**/*.ts",
    "lint:fix": "eslint --fix ./{src,__tests__}/**/*.ts",
    "test": "vitest run --coverage",
    "test:unit": "vitest run __tests__/unit --coverage",
    "test:integration": "vitest run __tests__/integration --coverage",
    "build": "ncc build ./src/index.ts -o lib",
    "tsc": "tsc --project tsconfig.test.json --noEmit",
    "format": "prettier --write \"src/**/*.ts\" \"__tests__/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"__tests__/**/*.ts\"",
    "release": "semantic-release",
    "release:dry-run": "semantic-release --dry-run",
    "postinstall": "husky"
  },
  "lint-staged": {
    "{src,__tests__}/**/*.ts": [
      "prettier --check",
      "eslint"
    ],
    "README.md": [
      "npx doctoc@2.1.0 --github"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/denmette/actions-hugo.git"
  },
  "keywords": [
    "GitHub",
    "Actions",
    "JavaScript",
    "TypeScript",
    "Hugo",
    "Setup"
  ],
  "author": "Maarten Casteels (@denmette)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/denmette/actions-hugo/issues"
  },
  "homepage": "https://github.com/denmette/actions-hugo#readme",
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/exec": "^3.0.0",
    "@actions/http-client": "^4.0.0",
    "@actions/io": "^3.0.2",
    "@actions/tool-cache": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/istanbul-lib-report": "^3.0.3",
    "@types/node": "^24.12.2",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@vercel/ncc": "^0.38.4",
    "@vitest/coverage-istanbul": "^4.1.4",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "eslint": "^10.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.2",
    "semantic-release": "^25.0.3",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
