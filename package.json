{
  "name": "actions-hugo",
  "version": "3.0.0",
  "description": "GitHub Actions for Hugo",
  "type": "module",
  "main": "lib/index.js",
  "engines": {
    "node": ">=24.10.0",
    "npm": ">=10.2.3"
  },
  "scripts": {
    "all": "npm run format:check && npm run lint && npm test",
    "lint": "eslint ./{src,__tests__}/**/*.ts",
    "lint:fix": "eslint --fix ./{src,__tests__}/**/*.ts",
    "test": "vitest run --coverage",
    "build": "ncc build ./src/index.ts -o lib",
    "tsc": "tsc --noEmit",
    "format": "prettier --write '**/*.ts'",
    "format:check": "prettier --check '**/*.ts'",
    "release": "semantic-release",
    "release:dry-run": "semantic-release --dry-run",
    "postinstall": "npx husky install"
  },
  "lint-staged": {
    "{src,__tests__}/**/*.ts": [
      "prettier --check",
      "eslint"
    ],
    "README.md": [
      "npx doctoc@2.1.0 --github"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/denmette/actions-hugo.git"
  },
  "keywords": [
    "GitHub",
    "Actions",
    "JavaScript",
    "TypeScript",
    "Hugo",
    "Setup"
  ],
  "author": "Maarten Casteels (@denmette)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/denmette/actions-hugo/issues"
  },
  "homepage": "https://github.com/denmette/actions-hugo#readme",
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/exec": "^3.0.0",
    "@actions/http-client": "^4.0.0",
    "@actions/io": "^3.0.2",
    "@actions/tool-cache": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/istanbul-lib-report": "^3.0.3",
    "@types/node": "^20.19.39",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@vercel/ncc": "^0.38.4",
    "@vitest/coverage-istanbul": "^3.1.1",
    "eslint": "^10.2.0",
    "husky": "^5.1.3",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "semantic-release": "^25.0.3",
    "typescript": "^4.9.5",
    "vitest": "^3.1.1"
  }
}
